<!DOCTYPE html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>继续教育学习助手</title>
        <style>
            :root {
                color-scheme: light;
                --bg: #f5f7fb;
                --surface: #ffffff;
                --surface-soft: #eef3f8;
                --text: #172033;
                --muted: #64748b;
                --border: #d8e0ea;
                --primary: #176b87;
                --primary-strong: #0f566d;
                --danger: #c2413a;
                --warning: #9a5a00;
                --shadow: 0 14px 38px rgba(25, 35, 55, 0.1);
            }

            body[data-theme="dark"] {
                color-scheme: dark;
                --bg: #10141b;
                --surface: #171d26;
                --surface-soft: #202936;
                --text: #edf2f7;
                --muted: #9fb0c3;
                --border: #2c3848;
                --primary: #5fb4c7;
                --primary-strong: #8bd0df;
                --danger: #ff8a80;
                --warning: #ffd166;
                --shadow: 0 18px 46px rgba(0, 0, 0, 0.28);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                min-height: 100dvh;
                background: var(--bg);
                color: var(--text);
                font-family:
                    -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei",
                    sans-serif;
                line-height: 1.5;
            }

            a {
                color: var(--primary);
                text-decoration: none;
                font-weight: 600;
            }

            a:hover {
                color: var(--primary-strong);
            }

            .page {
                width: min(1120px, calc(100% - 32px));
                margin: 0 auto;
                padding: 28px 0 32px;
            }

            .topbar {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 20px;
                margin-bottom: 22px;
            }

            .eyebrow {
                margin: 0 0 6px;
                color: var(--muted);
                font-size: 13px;
                font-weight: 700;
            }

            h1 {
                margin: 0;
                font-size: 28px;
                font-weight: 800;
            }

            .subtitle {
                margin: 8px 0 0;
                color: var(--muted);
                font-size: 14px;
            }

            .theme-toggle {
                flex: 0 0 auto;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                min-height: 38px;
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 0 12px;
                background: var(--surface);
                color: var(--text);
                cursor: pointer;
                font: inherit;
                font-weight: 700;
                box-shadow: var(--shadow);
            }

            .theme-toggle:hover {
                border-color: var(--primary);
            }

            .summary {
                display: grid;
                grid-template-columns: minmax(180px, 260px) 1fr;
                gap: 16px;
                align-items: stretch;
                margin-bottom: 16px;
            }

            .stat,
            .toolbar,
            .table-wrap,
            .log {
                border: 1px solid var(--border);
                border-radius: 8px;
                background: var(--surface);
                box-shadow: var(--shadow);
            }

            .stat {
                padding: 18px;
            }

            .stat-label {
                color: var(--muted);
                font-size: 13px;
                font-weight: 700;
            }

            .stat-value {
                margin-top: 8px;
                font-size: 34px;
                font-weight: 800;
            }

            .toolbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 14px;
                padding: 16px;
            }

            .filters {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 8px;
            }

            .filter-label {
                color: var(--muted);
                font-size: 13px;
                font-weight: 700;
            }

            .filter-link,
            .login-link,
            .action-link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-height: 32px;
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 0 10px;
                background: var(--surface-soft);
                color: var(--text);
                font-size: 13px;
                white-space: nowrap;
            }

            .filter-link.is-active,
            .login-link {
                border-color: var(--primary);
                background: var(--primary);
                color: #ffffff;
            }

            .table-wrap {
                overflow-x: auto;
            }

            table {
                width: 100%;
                min-width: 860px;
                border-collapse: collapse;
            }

            th,
            td {
                padding: 12px 10px;
                border-bottom: 1px solid var(--border);
                text-align: center;
                vertical-align: middle;
                font-size: 14px;
            }

            th {
                background: var(--surface-soft);
                color: var(--muted);
                font-size: 12px;
                font-weight: 800;
            }

            tbody tr:hover {
                background: var(--surface-soft);
            }

            tbody tr:last-child td {
                border-bottom: 0;
            }

            td:first-child {
                color: var(--text);
                font-weight: 800;
            }

            .credit {
                color: var(--warning);
                font-weight: 800;
            }

            .row-actions {
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                gap: 8px;
            }

            .action-link.danger {
                color: var(--danger);
            }

            .empty {
                padding: 28px 12px;
                color: var(--muted);
            }

            .log {
                margin-top: 16px;
                padding: 14px;
            }

            .log-title {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 10px;
                color: var(--muted);
                font-size: 13px;
                font-weight: 800;
            }

            .log textarea {
                display: block;
                width: 100%;
                min-height: 220px;
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 12px;
                background: var(--surface-soft);
                color: var(--text);
                font: 13px/1.5 Consolas, "Courier New", monospace;
                outline: none;
                resize: vertical;
                scroll-behavior: smooth;
            }

            .power {
                margin-top: 22px;
                color: var(--muted);
                font-size: 13px;
                text-align: right;
            }

            @media (max-width: 760px) {
                .page {
                    width: min(100% - 20px, 1120px);
                    padding-top: 18px;
                }

                .topbar,
                .toolbar,
                .summary {
                    display: block;
                }

                .theme-toggle,
                .toolbar,
                .stat {
                    margin-top: 14px;
                }

                h1 {
                    font-size: 24px;
                }

                .login-link {
                    margin-top: 12px;
                }

                .table-wrap {
                    overflow: visible;
                    border: 0;
                    background: transparent;
                    box-shadow: none;
                }

                table,
                tbody,
                tr,
                td {
                    display: block;
                    width: 100%;
                }

                table {
                    min-width: 0;
                    border-collapse: separate;
                    border-spacing: 0;
                }

                thead {
                    display: none;
                }

                tbody {
                    display: grid;
                    gap: 12px;
                }

                tbody tr {
                    border: 1px solid var(--border);
                    border-radius: 8px;
                    background: var(--surface);
                    box-shadow: var(--shadow);
                    overflow: hidden;
                }

                tbody tr:hover {
                    background: var(--surface);
                }

                td {
                    display: grid;
                    grid-template-columns: 88px 1fr;
                    gap: 12px;
                    align-items: center;
                    min-height: 42px;
                    padding: 10px 14px;
                    border-bottom: 1px solid var(--border);
                    text-align: right;
                }

                td::before {
                    content: attr(data-label);
                    color: var(--muted);
                    font-size: 12px;
                    font-weight: 800;
                    text-align: left;
                }

                td:first-child {
                    display: block;
                    padding: 14px;
                    background: var(--surface-soft);
                    text-align: left;
                    font-size: 17px;
                }

                td:first-child::before,
                td.empty::before {
                    content: "";
                    display: none;
                }

                tbody tr:last-child td {
                    border-bottom: 1px solid var(--border);
                }

                td:last-child {
                    display: block;
                    border-bottom: 0;
                }

                td:last-child::before {
                    display: block;
                    margin-bottom: 8px;
                    text-align: left;
                }

                .row-actions {
                    display: grid;
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    gap: 8px;
                }

                .action-link {
                    min-height: 38px;
                }

                .empty {
                    display: block;
                    border: 1px solid var(--border);
                    border-radius: 8px;
                    background: var(--surface);
                    text-align: center;
                }
            }
        </style>
    </head>
    <body>
        <main class="page">
            <header class="topbar">
                <div>
                    <!-- <p class="eyebrow">后台管理</p> -->
                    <h1>继续教育学习助手后台</h1>
                    <!-- <p class="subtitle">
                        没有你的名字？点击 <a href="/login">这里</a> 一键登录。
                    </p> -->
                </div>
                <button class="theme-toggle" type="button" id="themeToggle" aria-label="切换亮色和暗色模式">
                    <span id="themeIcon">暗</span>
                    <span id="themeText">暗色模式</span>
                </button>
            </header>

            <section class="summary" aria-label="学习统计">
                <div class="stat">
                    <div class="stat-label">当前老师</div>
                    <div class="stat-value"><%= total %></div>
                </div>

                <div class="toolbar">
                    <div class="filters" aria-label="筛选">
                        <span class="filter-label">筛选</span>
                        <a class="filter-link" data-status="all" href="?status=all">全部</a>
                        <a class="filter-link" data-status="finish" href="?status=finish">已完成</a>
                        <a class="filter-link" data-status="unfinish" href="?status=unfinish">未完成</a>
                    </div>
                    <a class="login-link" href="/login">新增老师</a>
                </div>
            </section>

            <section class="table-wrap" aria-label="老师学习状态">
                <table>
                    <thead>
                        <tr>
                            <th>老师名称</th>
                            <th>已选课程</th>
                            <th>未完成</th>
                            <th>总学时</th>
                            <th>获得学分</th>
                            <th>读书/反思</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data.length === 0) { %>
                            <tr>
                                <td class="empty" colspan="7">暂无老师数据</td>
                            </tr>
                        <% } %>
                        <% data.forEach(item=> { %>
                        <tr>
                            <td data-label="老师名称"><%= item.realName %></td>
                            <td data-label="已选课程"><%= item.courseInfo?.TotalCount ?? "-" %></td>
                            <td data-label="未完成"><%= item.courseInfo?.NotEndCount ?? "-" %></td>
                            <td data-label="总学时"><%= item.courseInfo?.totalPeriod ?? "-" %></td>
                            <td data-label="获得学分"><%= item.courseInfo?.obtainedValue ?? "-" %></td>
                            <td class="credit" data-label="读书/反思"><%= item.bookCredit ?? 0 %>/<%= item.weeklyCredit ?? 0 %></td>
                            <td data-label="操作">
                                <div class="row-actions">
                                    <a class="action-link" target="_blank" href="https://www.cdsjxjy.cn/cdcte/#/tokenLogin?token=<%= item.token %>">登录</a>
                                    <% if ((item.bookCredit ?? 0) + (item.weeklyCredit ?? 0) < 16) { %>
                                        <a class="action-link" target="_blank" href="/write?token=<%= item.token %>&username=<%= item.username %>">填写</a>
                                    <% } %>
                                    <a class="action-link" href="#" onclick="handleRestart('<%= item.username %>',event)">重启</a>
                                    <a class="action-link danger" href="#" onclick="handleDelete('<%= item.username %>',event)">删除</a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </section>

            <section class="log" aria-label="运行日志">
                <div class="log-title">
                    <span>运行日志</span>
                    <span>实时同步</span>
                </div>
                <textarea readonly></textarea>
            </section>

            <div class="power">develop by 帅哥程序猿</div>
        </main>

        <script>
            const THEME_KEY = "admin-theme";
            const themeToggle = document.querySelector("#themeToggle");
            const themeIcon = document.querySelector("#themeIcon");
            const themeText = document.querySelector("#themeText");

            function applyTheme(theme) {
                document.body.dataset.theme = theme;
                themeIcon.textContent = theme === "dark" ? "亮" : "暗";
                themeText.textContent = theme === "dark" ? "亮色模式" : "暗色模式";
                localStorage.setItem(THEME_KEY, theme);
            }

            const savedTheme = localStorage.getItem(THEME_KEY);
            const preferredTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
            applyTheme(savedTheme || preferredTheme);

            themeToggle.addEventListener("click", () => {
                const nextTheme = document.body.dataset.theme === "dark" ? "light" : "dark";
                applyTheme(nextTheme);
            });

            const status = new URLSearchParams(window.location.search).get("status") || "all";
            document.querySelectorAll(".filter-link").forEach((link) => {
                link.classList.toggle("is-active", link.dataset.status === status);
            });

            const ws = new WebSocket("/");
            ws.onmessage = (e) => {
                const log = document.querySelector(".log textarea");
                log.value += e.data;
                log.scrollTop = log.scrollHeight;
            };

            function handleDelete(username,event) {
                event.preventDefault();
                if (confirm("确定要删除吗？")) {
                    window.location.href = `/delete?username=${encodeURIComponent(username)}`;
                }
            }

            function handleRestart(username,event) {
                event.preventDefault();
                if (confirm("确定要重启该老师的学习任务吗？")) {
                    window.location.href = `/restart?username=${encodeURIComponent(username)}`;
                }
            }
        </script>
    </body>
</html>
